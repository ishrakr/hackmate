# Copy to .env for local Vite and Docker Compose runs.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional. Docker Compose sets this to "admin" for the separate admin container.
VITE_APP_MODE=
VITE_ADMIN_BASE_URL=

# Server-only secrets. Never expose these through VITE_ variables.
SUPABASE_SERVICE_ROLE_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
LLM_API_KEY=
LLM_PROVIDER=

APP_BASE_URL=http://localhost:5173
QR_TOKEN_SECRET=
